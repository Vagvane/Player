# =============================================================================
# NEUROFLIX VIDEO PROCESSOR - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
# Controls logging verbosity and debug output.
# Values: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Redis (BullMQ Job Queue)
# -----------------------------------------------------------------------------
# Video processing jobs are queued in Redis via BullMQ.
# Make sure Redis is running before starting the video processor.

# Redis server hostname or IP address
REDIS_HOST=localhost

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis password (leave empty if no authentication is configured)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
# R2 is used to store original uploads and processed HLS files.
# Find these values in your Cloudflare dashboard:
#   Dashboard -> R2 -> Manage R2 API Tokens

# Your Cloudflare account ID (found in the right sidebar of any Cloudflare page)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API token access key ID
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 API token secret access key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Name of the R2 bucket used for video storage
R2_BUCKET_NAME=neuroflix-videos

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# The video processor calls the backend API to update video status
# (PROCESSING → READY | FAILED) and store HLS/thumbnail paths.

# Base URL of the Neuroflix backend API (no trailing slash)
BACKEND_API_URL=http://localhost:3001/api/v1

# Internal API key used to authenticate video processor requests to the backend.
# Must match the VIDEO_PROCESSOR_API_KEY set in the backend .env file.
VIDEO_PROCESSOR_API_KEY=your-internal-api-key-for-video-processor

# -----------------------------------------------------------------------------
# FFmpeg
# -----------------------------------------------------------------------------
# FFmpeg binaries are automatically detected from ./ffmpeg/bin/
# Place ffmpeg.exe and ffprobe.exe in:
#   video-processor/ffmpeg/bin/ffmpeg.exe
#   video-processor/ffmpeg/bin/ffprobe.exe
#
# No configuration needed if FFmpeg is in video-processor/ffmpeg/bin/
# Run `npm run download:ffmpeg` to download FFmpeg automatically.
