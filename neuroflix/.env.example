# =============================================================================
# Neuroflix — Environment Variable Templates
# =============================================================================
# Copy the relevant section into each service's .env file, or run:
#   powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1
# which copies .env.example → .env for all three services automatically.
# =============================================================================


# -----------------------------------------------------------------------------
# Frontend  →  frontend/.env
# -----------------------------------------------------------------------------

VITE_API_URL=http://localhost:3001/api/v1


# -----------------------------------------------------------------------------
# Backend  →  backend/.env
# -----------------------------------------------------------------------------

NODE_ENV=development
PORT=3001

# PostgreSQL — use the Docker defaults below, or your own Supabase connection string
DATABASE_URL=postgresql://neuroflix:neuroflix_dev@localhost:5432/neuroflix

# JWT — replace with a long random string before deploying to production
# Generate one: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# Cloudflare R2 — https://dash.cloudflare.com/ → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=neuroflix-videos

# Redis — Docker default (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Frontend origin for CORS — change to your Vercel URL in production
FRONTEND_URL=http://localhost:5173

# Shared secret for internal backend ↔ video-processor communication
VIDEO_PROCESSOR_API_KEY=change-this-to-any-random-string


# -----------------------------------------------------------------------------
# Video Processor  →  video-processor/.env
# -----------------------------------------------------------------------------

NODE_ENV=development

# Redis — Docker default (matches docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudflare R2 — same credentials as backend
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=neuroflix-videos

# Backend API — used to report processing status
BACKEND_API_URL=http://localhost:3001/api/v1
VIDEO_PROCESSOR_API_KEY=change-this-to-any-random-string


# =============================================================================
# Docker (PostgreSQL + Redis)
# =============================================================================
# Run:  docker compose up -d
#
# This starts:
#   neuroflix-postgres  → localhost:5432  (user: neuroflix, pass: neuroflix_dev, db: neuroflix)
#   neuroflix-redis     → localhost:6379
#
# No Supabase or Upstash account required for local development.
# =============================================================================
