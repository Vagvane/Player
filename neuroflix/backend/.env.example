# =============================================================================
# NEUROFLIX BACKEND - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
# SECURITY WARNING:
#   - NEVER commit your .env file to version control
#   - NEVER share secrets in plain text
#   - Use a secrets manager (e.g., AWS Secrets Manager, Vault) in production
#   - Rotate secrets regularly, especially after any suspected breach
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your actual values
# =============================================================================


# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Application environment
# Values: development | test | production
# - development: Enables verbose logging, stack traces in error responses, relaxed CORS
# - production:  Disables debug logs, hides stack traces, strict CORS enforcement
NODE_ENV=development

# Port the Express server will listen on
# Default: 3001 (avoids conflict with frontend on 5173 or 3000)
PORT=3001


# =============================================================================
# DATABASE (Supabase PostgreSQL)
# =============================================================================

# Full PostgreSQL connection string used by Prisma ORM
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
#
# Where to find this:
#   Supabase Dashboard → Project Settings → Database → Connection String (URI)
#
# SECURITY WARNING:
#   Use the "pooler" connection string in production to avoid exhausting
#   database connections (Supabase provides a PgBouncer URL on port 6543).
#
# Example (Supabase direct):
#   DATABASE_URL=postgresql://postgres:mypassword@db.abcdefgh.supabase.co:5432/postgres
#
# Example (Supabase pooler - recommended for production):
#   DATABASE_URL=postgresql://postgres:mypassword@db.abcdefgh.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@host:5432/database


# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# Secret key used to sign and verify JSON Web Tokens
#
# SECURITY WARNING:
#   - Must be at least 32 characters; 64+ characters recommended for production
#   - Use a cryptographically random string (e.g., `openssl rand -hex 64`)
#   - Changing this value invalidates ALL existing tokens (all users are logged out)
#   - Store this securely — treat it like a private key
#
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-256-bit-key

# Access token expiry duration
# Format: Zeit/ms string — e.g., 15m, 1h, 24h, 7d
# Shorter lifetimes are more secure; use refresh tokens for long sessions
JWT_EXPIRES_IN=24h

# Refresh token expiry duration
# Refresh tokens are long-lived and used to obtain new access tokens
# SECURITY: Store refresh tokens securely (httpOnly cookies or encrypted storage)
JWT_REFRESH_EXPIRES_IN=7d


# =============================================================================
# CLOUDFLARE R2 STORAGE
# =============================================================================
# Cloudflare R2 is S3-compatible object storage used for video files.
# The backend uses AWS SDK v3 pointed at your R2 endpoint.
#
# Setup guide:
#   1. Log in to Cloudflare Dashboard → R2 Object Storage
#   2. Create a bucket (e.g., neuroflix-videos)
#   3. Go to Manage R2 API Tokens → Create API Token
#   4. Copy Account ID from the R2 overview page
#
# SECURITY WARNING:
#   - Use a scoped API token with only the permissions required (Object Read & Write)
#   - Rotate R2 tokens regularly
#   - Never expose R2_SECRET_ACCESS_KEY to the client/frontend

# Your Cloudflare Account ID (found in the right sidebar of the Cloudflare dashboard)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API Token Access Key ID (acts like an AWS Access Key)
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 API Token Secret Access Key (acts like an AWS Secret Key)
# SECURITY WARNING: Treat this like a password — never log or expose it
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Name of the R2 bucket where video files are stored
# Must already exist in your Cloudflare account
R2_BUCKET_NAME=neuroflix-videos

# Public base URL for the R2 bucket (used to construct public asset URLs)
# Format: https://<bucket-name>.<account-id>.r2.dev  (default R2 public URL)
#      or a custom domain you've configured in Cloudflare
# Leave empty if the bucket is private (signed URLs will be used instead)
R2_PUBLIC_URL=https://your-bucket.r2.dev


# =============================================================================
# FRONTEND URL (CORS)
# =============================================================================

# The URL of the frontend application
# Used to configure CORS so the browser can make cross-origin requests to this API
#
# Development default: http://localhost:5173  (Vite dev server)
# Production example:  https://app.neuroflix.com
#
# SECURITY WARNING:
#   Set this to your exact production domain in production.
#   Wildcards (*) should NEVER be used in production for authenticated APIs.
FRONTEND_URL=http://localhost:5173


# =============================================================================
# REDIS (Upstash — Rate Limiting & Job Queue)
# =============================================================================

# Redis connection URL used for:
#   - express-rate-limit store (distributed rate limiting across multiple instances)
#   - BullMQ / job queue for video processing tasks (future integration)
#
# Upstash provides a serverless Redis instance with a free tier.
# Setup guide:
#   1. Go to https://upstash.com → Create Database
#   2. Copy the Redis connection URL from the "Details" tab
#
# Format:
#   redis://default:<password>@<host>:<port>
#   rediss://default:<password>@<host>:<port>   (TLS — recommended for production)
#
# SECURITY WARNING:
#   Use TLS (rediss://) in production.
#   The password grants full access to the Redis instance — keep it secret.
REDIS_URL=redis://default:password@host:6379


# =============================================================================
# LOGGING (Optional)
# =============================================================================

# Minimum log level for the application logger
# Values: debug | info | warn | error
#
# - debug:  All messages including low-level diagnostic information (development)
# - info:   General operational messages (requests, startup events)
# - warn:   Potentially harmful situations that don't cause errors
# - error:  Error events that might still allow the app to continue running
#
# Recommended:
#   development → debug
#   production  → info or warn  (avoid debug in production to reduce noise & log costs)
LOG_LEVEL=debug
